            <td>See note above about <i>item</i>
            </td>
          </tr>
          <tr>
            <td>item.packageType</td>
            <td>equivalent</td>
            <td>Medication</td>
            <td>extension:packageType</td>
            <td>See note above about <i>item</i>
            </td>
          </tr>
          <tr>
            <td>device</td>
            <td>equivalent</td>
            <td>Medication</td>
            <td>extension:device</td>
            <td></td>
          </tr>
          <tr>
            <td>device.deviceQuantity</td>
